# Copy this file to .env and fill in your keys. .env is gitignored — never commit it.
# One file, all tools (build-anki.py, svg-visual-audit.mjs, the spine phases) read from here.

# Required for: card extraction (Anki), figure audit, research/fact-check phases
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Optional. Only used if you turn audio on (anki-config.yaml: audio: true)
ELEVENLABS_API_KEY=
